<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- ── IISNode Handler ───────────────────────────────────────────────── -->
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <!-- ── Route all requests to server.js ──────────────────────────────── -->
    <rewrite>
      <rules>
        <!-- Redirect HTTP to HTTPS -->
        <rule name="HTTP to HTTPS" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTPS}" pattern="^OFF$" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
        </rule>

        <!-- Skip rewrite for iisnode internal requests -->
        <rule name="iisnode Internals" stopProcessing="true">
          <match url="iisnode*" />
          <action type="None" />
        </rule>

        <!-- Route everything to server.js -->
        <rule name="Express Routes" stopProcessing="true">
          <match url="/*" />
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- ── iisnode Configuration ─────────────────────────────────────────── -->
    <iisnode
      nodeProcessCommandLine="node"
      watchedFiles="web.config;*.js"
      loggingEnabled="true"
      logDirectory="iisnode"
      debuggingEnabled="false"
      maxConcurrentRequestsPerProcess="1024"
      maxNamedPipeConnectionRetry="3"
      namedPipeConnectionRetryDelay="2000"
      asyncCompletionThreadCount="0"
      initialRequestBufferSize="4096"
      maxRequestBufferSize="65536"
      uncFileChangesPollingInterval="5000"
      gracefulShutdownTimeout="60000"
    />

    <!-- ── Security Headers ──────────────────────────────────────────────── -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options"        value="SAMEORIGIN" />
        <add name="X-XSS-Protection"       value="1; mode=block" />
      </customHeaders>
    </httpProtocol>

    <!-- ── Compression ───────────────────────────────────────────────────── -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />

    <!-- ── Request Limits (for large payloads) ───────────────────────────── -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="52428800" /> <!-- 50MB -->
      </requestFiltering>
    </security>

    <!-- ── Error Pages ───────────────────────────────────────────────────── -->
    <httpErrors existingResponse="PassThrough" />

  </system.webServer>

  <!-- ── Environment Variables ─────────────────────────────────────────────── -->
  <appSettings>
    <add key="NODE_ENV"          value="production" />
    <add key="PORT"              value="5000" />
    <add key="DB_SERVER"         value="192.168.20.160" />
    <add key="DB_NAME"           value="cbs2_test" />
    <add key="DB_USER"           value="adv" />
    <add key="DB_PASSWORD"       value="Om_sai_#~!^(ram1" />
    <add key="DB_PORT"           value="1433" />
    <add key="DB_ENCRYPT"        value="false" />
  </appSettings>

</configuration>